# Example environment file for Vennekredsen
#
# Production usage:
#   cp .env.example .env.local
#   docker compose --env-file .env.local -f docker-compose.yml up -d
#
# Development usage:
#   dev.sh uses .env.dev and .env.dev.local
#   (it auto-creates .env.dev.local from .env.dev if missing)

# Required by docker-compose.yml and api/app.py
POSTGRES_DB=vennekredsen_prod
POSTGRES_USER=vennekredsen_user
POSTGRES_PASSWORD=change_me_to_a_strong_password
JWT_SECRET=change_me_to_a_long_random_secret
INTERNAL_TOKEN=replace_with_cloudflare_tunnel_token

# Optional external host ports for docker-compose.yml
FRONTEND_EXTERNAL_PORT=80
API_EXTERNAL_PORT=5000
DB_EXTERNAL_PORT=5432

# Optional API override (default is "db")
DB_HOST=db

# Optional full DB URI override (normally not needed)
# SQLALCHEMY_DATABASE_URI=postgresql://user:password@db:5432/vennekredsen_prod

# Optional dev-only values for docker-compose.local.yml profile "tools" (pgAdmin)
PGADMIN_EMAIL=admin@dev.local
PGADMIN_PASSWORD=change_me_pgadmin_password
